# 1. Build Stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /app

# Copy and restore project files
COPY *.csproj ./
RUN dotnet restore

# Copy everything else and build the release
COPY . ./
RUN dotnet publish -c Release -o out

# 2. Runtime Stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/out ./

# START COMMAND
# Replace "BuildMate-WEB.dll" with the actual name of your output assembly DLL.
# (For example, if your project is called BuildMate.csproj, it will be BuildMate.dll)
ENTRYPOINT ["dotnet", "BuildMate.dll"]
