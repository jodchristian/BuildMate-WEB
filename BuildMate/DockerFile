# 1. Build Stage
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /app

# Copy the csproj into a matching subfolder and restore
COPY BuildMate-WEB/*.csproj ./BuildMate-WEB/
RUN dotnet restore BuildMate-WEB/*.csproj

# Copy the rest of the files into the subfolder
COPY BuildMate-WEB/ ./BuildMate-WEB/

# Publish from the subdirectory
RUN dotnet publish BuildMate-WEB/*.csproj -c Release -o out

# 2. Runtime Stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app/out ./

ENTRYPOINT ["dotnet", "BuildMate.dll"]
