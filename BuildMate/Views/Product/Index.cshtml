@model Buildmate.Models.ProductListViewModel
@{
    ViewData["Title"] = "Products / Materials";
    Layout = "_Layout";
}

<div class="page-header-row">
    <div>
        <h2 class="page-title">Product Management and Listing</h2>
        <p class="page-subtitle">Manage all your products and materials in one place.</p>
    </div>
    <a href="#" onclick="openProductPanel('@Url.Action("Create")'); return false;" class="btn-apply">+ Add New Product</a>
</div>

<!-- STAT CARDS -->
<div class="stat-cards">
    <div class="stat-card blue">
        <div>
            <small>Total Products</small>
            <h3>@Model.TotalProducts</h3>
            <span>All products</span>
        </div>
        <div class="stat-icon-wrapper"><img src="~/images/totalpro.png" /></div>
    </div>
    <div class="stat-card yellow">
        <div>
            <small>Active Products</small>
            <h3>@Model.ActiveCount</h3>
            <span>Published and visible</span>
        </div>
        <div class="stat-icon-wrapper"><img src="~/images/activeprod.png" /></div>
    </div>
    <div class="stat-card green">
        <div>
            <small>Inactive Products</small>
            <h3>@Model.InactiveCount</h3>
            <span>Draft or inactive</span>
        </div>
        <div class="stat-icon-wrapper"><img src="~/images/inactiveprod.png" /></div>
    </div>
    <div class="stat-card purple">
        <div>
            <small>Categories</small>
            <h3>@Model.CategoryCount</h3>
            <span>Product categories</span>
        </div>
        <div class="stat-icon-wrapper"><img src="~/images/categor.png" /></div>
    </div>
</div>

<!-- FILTER BAR -->
<div class="panel filter-panel">
    <form method="get" asp-action="Index" class="filter-form">
        <div class="search-wrapper">
            <div class="search-box">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="search" value="@Model.SearchTerm" placeholder="Search by product name or SKU..." />
            </div>
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select name="status">
                <option value="">All Status</option>
                <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Category</label>
            <select name="category">
                <option value="">All Categories</option>
                <option value="Cement" selected="@(Model.CategoryFilter == "Cement")">Cement</option>
                <option value="Steel" selected="@(Model.CategoryFilter == "Steel")">Steel</option>
                <option value="Electrical" selected="@(Model.CategoryFilter == "Electrical")">Electrical</option>
                <option value="Plumbing" selected="@(Model.CategoryFilter == "Plumbing")">Plumbing</option>
                <option value="Roofing" selected="@(Model.CategoryFilter == "Roofing")">Roofing</option>
                <option value="Insulation" selected="@(Model.CategoryFilter == "Insulation")">Insulation</option>
            </select>
        </div>
        <a href="/Product/Index" class="btn-clear">Clear</a>
        <button type="submit" class="btn-apply">Apply Filters</button>
    </form>
</div>

<!-- TABLE PANEL -->
<div class="panel">
    <table class="rfq-table full-table">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Sku</th>
                <th>Category</th>
                <th>Unit</th>
                <th>Price</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Products)
            {
                <tr>
                    <td>
                        <div class="product-cell">
                            <img src="~/images/@p.ImageFile" class="product-thumb-img" />
                            <div>
                                <strong>@p.Name</strong><br />
                                <small class="muted">@p.Description</small>
                            </div>
                        </div>
                    </td>
                    <td>@p.Sku</td>
                    <td>@p.Category</td>
                    <td>@p.Unit</td>
                    <td>₱@p.Price.ToString("N2")</td>
                    <td>
                        <span class="badge-status @(p.Status == "Active" ? "delivered" : "cancelled")">@p.Status</span>
                    </td>
                    <td>
                        <a href="#" onclick="openProductPanel('@Url.Action("Edit", new { id = p.Id })'); return false;" class="btn-edit"><i class="bi bi-pencil"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="table-footer-row">
        <span>Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) to @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalFilteredCount)) of @Model.TotalFilteredCount products</span>

        <div class="pagination">
            <a href="@Url.Action("Index", new { search = Model.SearchTerm, status = Model.StatusFilter, category = Model.CategoryFilter, page = 1 })" class="page-btn">«</a>
            @for (int i = 1; i <= Math.Min(Model.TotalPages, 5); i++)
            {
                <a href="@Url.Action("Index", new { search = Model.SearchTerm, status = Model.StatusFilter, category = Model.CategoryFilter, page = i })"
                   class="page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
            }
            @if (Model.TotalPages > 5)
            {
                <span class="page-btn" style="border:none;">...</span>
                <a href="@Url.Action("Index", new { search = Model.SearchTerm, status = Model.StatusFilter, category = Model.CategoryFilter, page = Model.TotalPages })" class="page-btn">@Model.TotalPages</a>
            }
            <a href="@Url.Action("Index", new { search = Model.SearchTerm, status = Model.StatusFilter, category = Model.CategoryFilter, page = Model.TotalPages })" class="page-btn">»</a>
        </div>
    </div>
    <!-- MODAL CONTAINER (initially empty) -->
    <div id="productPanelContainer"></div>

    @section Scripts {
        <script>
                                function openProductPanel(url) {
                    fetch(url)
                        .then(res => res.text())
                        .then(html => {
                            const container = document.getElementById('productPanelContainer');
                            container.innerHTML = html;

                            // Manually execute any <script> tags since innerHTML doesn't run them
                            const scripts = container.querySelectorAll('script');
                            scripts.forEach(oldScript => {
                                const newScript = document.createElement('script');
                                if (oldScript.src) {
                                    newScript.src = oldScript.src;
                                } else {
                                    newScript.textContent = oldScript.textContent;
                                }
                                document.body.appendChild(newScript);
                                oldScript.remove();
                            });
                        });
                }
        </script>
    }
</div>