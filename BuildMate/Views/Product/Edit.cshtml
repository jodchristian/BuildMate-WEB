@model Buildmate.Models.Product
@{
    Layout = null;
}

<div class="wizard-overlay-side">
    <div class="wizard-panel">
        <div class="wizard-header">
            <div>
                <h3>Edit Product</h3>
                <p>Update the product details below.</p>
            </div>
            <a href="#" onclick="closeProductPanel(); return false;" class="wizard-close">&times;</a>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="wizard-section">
                <div class="form-group full-width">
                    <label>Product Name</label>
                    <input asp-for="Name" class="form-input" required />
                </div>
                <div class="form-group full-width">
                    <label>SKU</label>
                    <input asp-for="Sku" class="form-input" required />
                </div>
                <div class="form-group full-width">
                    <label>Category</label>
                    <select asp-for="Category" class="form-input">
                        <option value="Cement">Cement</option>
                        <option value="Steel">Steel</option>
                        <option value="Electrical">Electrical</option>
                        <option value="Plumbing">Plumbing</option>
                        <option value="Roofing">Roofing</option>
                        <option value="Insulation">Insulation</option>
                    </select>
                </div>
                <div class="form-group full-width">
                    <label>Unit</label>
                    <input asp-for="Unit" class="form-input" required />
                </div>
                <div class="form-group full-width">
                    <label>Price (₱)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-input" required />
                </div>
                <div class="form-group full-width">
                    <label>Status</label>
                    <select asp-for="Status" class="form-input">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
                <div class="form-group full-width">
                    <label>Description</label>
                    <textarea asp-for="Description" class="form-input" rows="3"></textarea>
                </div>
            </div>

            <div class="wizard-footer">
                <a href="#" onclick="closeProductPanel(); return false;" class="btn-clear">Cancel</a>               
                <button type="submit" class="btn-apply">Update Product</button>
            </div>
        </form>
    </div>
</div>