@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Buildmate - Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <div class="login-page-wrapper">
        <div class="login-card">
            <!-- LEFT PANEL -->
            <div class="login-left-panel">
            </div>

            <!-- RIGHT PANEL -->
            <div class="login-right-panel">
                <div class="login-topbar">
                    <a href="@Url.Action("Login")" class="back-to-login"><i class="bi bi-chevron-left"></i> Back to Login</a>
                    <div class="lang-select"><i class="bi bi-globe"></i> English <i class="bi bi-chevron-down"></i></div>
                    <div class="topbar-divider"></div>
                    <div class="help-text">Need help? <a href="#">Contact Support</a></div>
                </div>

                <div class="login-form-container">
                    <div class="forgot-icon-wrapper">
                        <img src="~/images/forgot.png" class="forgot-icon" />
                    </div>

                    <h2>Forgot Password?</h2>
                    <p class="login-form-sub center-wide">No worries! Enter your email address and we'll send you a link to reset your password.</p>

                    @if (TempData["ResetSent"] != null)
                    {
                        <div class="success-alert">
                            <i class="bi bi-check-circle"></i> Reset link sent! Please check your email.
                        </div>
                    }

                    <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                        <div class="form-group full-width">
                            <label>Email Address</label>
                            <div class="input-with-icon">
                                <i class="bi bi-envelope"></i>
                                <input type="email" name="email" placeholder="Enter email address" required />
                            </div>
                        </div>

                        <div class="info-note">
                            <i class="bi bi-info-circle"></i>
                            <span>We'll send a password reset link to your email. Please check your inbox and spam folder.</span>
                        </div>

                        <button type="submit" class="btn-login">Send Reset Link</button>
                    </form>

                    <div class="or-divider"><span>OR</span></div>

                    <button class="btn-outline-full">Reset via Mobile Number</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>