<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Buildmate - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="app-wrapper">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <img src="~/images/logo.png" alt="Buildmate Logo" class="brand-logo-img" />
                <div class="brand-text">Build<span>mate</span></div>
            </div>

            <nav class="nav-menu">
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                }
                <a class="nav-item @(currentController == "Dashboard" ? "active" : "")" href="/Dashboard/Index">
                    <img src="~/images/dashboard.png" class="nav-icon" /> Dashboard
                </a>
                <a class="nav-item @(currentController == "Rfq" ? "active" : "")" href="/Rfq/Index">
                    <img src="~/images/rfq.png" class="nav-icon" /> RFQ Requests <span class="badge-red">8</span>
                </a>
                <a class="nav-item @(currentController == "Order" ? "active" : "")" href="/Order/Index">
                    <img src="~/images/orders.png" class="nav-icon" /> Orders
                </a>
                <a class="nav-item @(currentController == "Product" ? "active" : "")" href="/Product/Index">
                    <img src="~/images/productsmaterials.png" class="nav-icon" /> Products / Materials
                </a>
                <a class="nav-item @(currentController == "Pricing" ? "active" : "")" href="/Pricing/Index">
                    <img src="~/images/pricing.png" class="nav-icon" /> Pricing
                </a>
                <a class="nav-item @(currentController == "CompanyProfile" ? "active" : "")" href="/CompanyProfile/Index">
                    <img src="~/images/companyprof.png" class="nav-icon" /> Company Profile
                </a>
                <a class="nav-item @(currentController == "Notification" ? "active" : "")" href="/Notification/Index">
                    <img src="~/images/notif.png" class="nav-icon" /> Notifications
                </a>
                <a class="nav-item @(currentController == "Settings" ? "active" : "")" href="/Settings/Index">
                    <img src="~/images/settings.png" class="nav-icon" /> Settings
                </a>
                <a href="@Url.Action("Logout", "Account")" style="display:flex; align-items:center; gap:10px; color:#ef4444; text-decoration:none; font-size:14px; padding:10px 12px; border-radius:8px;">
                    <i class="bi bi-box-arrow-left"></i> Sign Out
                </a>
            </nav>

            <div class="help-box">
                <p><img src="~/images/headset.png" class="help-icon" /> Need Help?</p>
                <small>Visit our help center or contact support.</small>
                <button class="btn-support">Contact Support</button>
            </div>
            
            
        </aside>

        <!-- MAIN CONTENT -->
        <main class="main-content">
            <header class="topbar">
                <div class="breadcrumb">@ViewData["Title"]</div>                
                <div class="topbar-right">
                    <a href="/Notification/Index" class="topbar-icon-link"><i class="bi bi-bell"></i></a>
                    <a href="/Message/Index" class="topbar-icon-link"><i class="bi bi-chat-dots"></i></a>
                    <div class="profile">
                        <img src="~/images/company.png" class="avatar-img" alt="Company" />
                        <div>
                            <div class="profile-name">BuildWell Enterprises</div>
                            <small>Supplier</small>
                        </div>
                        <i class="bi bi-chevron-down"></i>
                    </div>
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>